# ==========================================
# CONFIGURATION HôtelERP
# ==========================================
# Copiez ce fichier sous .env et adaptez les valeurs.

# Sécurité
SECRET_KEY="CHANGEZ-ME-pour-un-environnement-de-production"
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS="localhost,127.0.0.1,votre-domaine.com"
CSRF_TRUSTED_ORIGINS="https://votre-domaine.com"

# Base de données
# PostgreSQL recommandé en production :
# DATABASE_URL="postgres://user:password@localhost:5432/hotel_db"
